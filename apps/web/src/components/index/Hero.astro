---
import { Badge } from "@/components/ui/badge"
---

<header class="space-y-4">
	<Badge className="w-fit border border-white/12 bg-white/8 px-3 py-1 text-[0.65rem] font-medium tracking-[0.28em] uppercase text-white/70 hover:bg-white/8">
		compilador web
	</Badge>
	<div class="space-y-2">
		<h1 class="text-3xl leading-none font-medium tracking-[-0.06em] text-white sm:text-4xl lg:text-[3.4rem]">
			Escribe el lenguaje y compila a PostgreSQL.
		</h1>
		<p class="max-w-xl text-sm leading-6 text-white/48 sm:text-[0.95rem]">
			Entrada, SQL compilado, esquema detectado y archivos de salida desde la misma interfaz.
		</p>
	</div>
</header>
